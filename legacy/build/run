#!/bin/bash
# build — assemble, link, run
set -e
cd "$(dirname "$0")/.."

OUT=.build
mkdir -p "$OUT"

# -DDEBUG for QEMU builds (debugcon echo). Omit for bare metal (bash build/run img).
DBGFLAG=""
[ "$1" != "img" ] && DBGFLAG="-DDEBUG"

nasm $DBGFLAG -f elf32 "[2][x86][cpu][entry][mode switch][page tables][AP wake][32 bit from boot, exits 64 bit to lattice].asm" -o "$OUT/x86.o"
nasm $DBGFLAG -f elf32 "[3][x86][handoff][lattice start][inits JIT, runs genesis, enters market, never returns].asm" -o "$OUT/handoff.o"
nasm $DBGFLAG -f elf32 "[4][x86][driver][equation][JIT][cache][4 coordinates in, x86 function out, sealed].asm" -o "$OUT/equation.o"
nasm $DBGFLAG -f elf32 "[5][x86][driver][walker][interpreter][wave bytes in, decodes coordinates, calls equation, sealed].asm" -o "$OUT/walker.o"
nasm $DBGFLAG -f elf32 "[6][x86][walk][genesis][founding][runs once at boot, inits loops, discovers hardware].asm" -o "$OUT/genesis.o"
nasm $DBGFLAG -f elf32 "walks/input.asm" -o "$OUT/input.o"
nasm $DBGFLAG -f elf32 "walks/mouse.asm" -o "$OUT/mouse.o"
nasm $DBGFLAG -f elf32 "walks/drain.asm" -o "$OUT/drain.o"
nasm $DBGFLAG -f elf32 "walks/kbd_consumer.asm" -o "$OUT/kbd_consumer.o"

ld -m elf_i386 -T build/link.ld \
    "$OUT"/x86.o \
    "$OUT"/handoff.o \
    "$OUT"/equation.o \
    "$OUT"/walker.o \
    "$OUT"/genesis.o \
    "$OUT"/input.o \
    "$OUT"/mouse.o \
    "$OUT"/drain.o \
    "$OUT"/kbd_consumer.o \
    -o "$OUT/nomos.elf"

echo "built: $(stat -c%s "$OUT/nomos.elf") bytes"

# ── bootable disk image (MBR + flat kernel) ──
if [ "$1" = "img" ]; then
    objcopy -O binary "$OUT/nomos.elf" "$OUT/nomos.bin"
    KSIZE=$(stat -c%s "$OUT/nomos.bin")
    KSECTORS=$(( (KSIZE + 511) / 512 ))
    if [ $KSECTORS -le 127 ]; then
        S1=$KSECTORS; S2=0
    else
        S1=127; S2=$(( KSECTORS - 127 ))
    fi
    nasm -DSEC1=$S1 -DSEC2=$S2 "[1][x86][boot][mbr][16 bit][loads kernel from disk, sets VESA mode].asm" -o "$OUT/mbr.bin"
    IMGSECTORS=$(( 1 + KSECTORS + 64 ))
    dd if=/dev/zero of="$OUT/nomos.img" bs=512 count=$IMGSECTORS 2>/dev/null
    dd if="$OUT/mbr.bin" of="$OUT/nomos.img" conv=notrunc 2>/dev/null
    dd if="$OUT/nomos.bin" of="$OUT/nomos.img" bs=512 seek=1 conv=notrunc 2>/dev/null
    echo "image: $KSIZE bytes kernel, $KSECTORS sectors ($S1+$S2)"
    echo "  dd if=$OUT/nomos.img of=/dev/sdX bs=512"
    exit 0
fi

# ── always build MBR image ──
nasm "[1][x86][boot][mbr][16 bit][loads kernel from disk, sets VESA mode].asm" -o "$OUT/mbr.bin"
objcopy -O binary "$OUT/nomos.elf" "$OUT/nomos.bin"
dd if=/dev/zero of="$OUT/nomos.img" bs=1M count=1 2>/dev/null
dd if="$OUT/mbr.bin" of="$OUT/nomos.img" conv=notrunc 2>/dev/null
dd if="$OUT/nomos.bin" of="$OUT/nomos.img" bs=512 seek=1 conv=notrunc 2>/dev/null

QEMU_HW="-device e1000 -smp ${2:-4}"

if [ "$1" = "headless" ]; then
    qemu-system-x86_64 -kernel $OUT/nomos.elf -m 128M -no-reboot \
        -debugcon stdio -serial file:/dev/stderr $QEMU_HW \
        -cpu Skylake-Server -display none
elif [ "$1" = "kvm" ]; then
    qemu-system-x86_64 -hda $OUT/nomos.img -m 128M -no-reboot \
        -debugcon stdio -serial file:/dev/stderr $QEMU_HW \
        -enable-kvm -cpu host -display none
else
    KVM=""
    [ -w /dev/kvm ] && KVM="-enable-kvm -cpu host"
    qemu-system-x86_64 -hda $OUT/nomos.img -m 128M -no-reboot \
        -serial file:/dev/null -debugcon stdio $QEMU_HW \
        ${KVM:-"-cpu Skylake-Server"} -vga std
fi
