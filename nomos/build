#!/bin/bash
# build — assemble, link, run
set -e
cd "$(dirname "$0")"

OUT=.build
mkdir -p "$OUT"

nasm -f elf32 asm/bootloader.asm -o "$OUT/boot.o"
nasm -f elf32 asm/equation.asm -o "$OUT/equation.o"
nasm -f elf32 lat/genesis.asm -o "$OUT/genesis.o"

ld -m elf_i386 -T link.ld \
    "$OUT"/boot.o \
    "$OUT"/equation.o \
    "$OUT"/genesis.o \
    -o "$OUT/nomos.elf"

echo "built: $(stat -c%s "$OUT/nomos.elf") bytes"

# ── bootable disk image (MBR + flat kernel) ──
if [ "$1" = "img" ]; then
    objcopy -O binary "$OUT/nomos.elf" "$OUT/nomos.bin"
    KSIZE=$(stat -c%s "$OUT/nomos.bin")
    KSECTORS=$(( (KSIZE + 511) / 512 ))
    # split into two chunks (max 127 each)
    if [ $KSECTORS -le 127 ]; then
        S1=$KSECTORS; S2=0
    else
        S1=127; S2=$(( KSECTORS - 127 ))
    fi
    nasm -DSEC1=$S1 -DSEC2=$S2 mbr.asm -o "$OUT/mbr.bin"
    # create disk image sized to fit
    IMGSECTORS=$(( 1 + KSECTORS + 64 ))  # MBR + kernel + padding
    dd if=/dev/zero of="$OUT/nomos.img" bs=512 count=$IMGSECTORS 2>/dev/null
    dd if="$OUT/mbr.bin" of="$OUT/nomos.img" conv=notrunc 2>/dev/null
    dd if="$OUT/nomos.bin" of="$OUT/nomos.img" bs=512 seek=1 conv=notrunc 2>/dev/null
    echo "image: $KSIZE bytes kernel, $KSECTORS sectors ($S1+$S2)"
    echo "  dd if=$OUT/nomos.img of=/dev/sdX bs=512"
    exit 0
fi

# ── always build MBR image ──
nasm mbr.asm -o "$OUT/mbr.bin"
objcopy -O binary "$OUT/nomos.elf" "$OUT/nomos.bin"
dd if=/dev/zero of="$OUT/nomos.img" bs=1M count=1 2>/dev/null
dd if="$OUT/mbr.bin" of="$OUT/nomos.img" conv=notrunc 2>/dev/null
dd if="$OUT/nomos.bin" of="$OUT/nomos.img" bs=512 seek=1 conv=notrunc 2>/dev/null

QEMU_HW="-device e1000 -smp ${2:-4}"

if [ "$1" = "headless" ]; then
    # multiboot (no VESA, debugcon to stdout)
    qemu-system-x86_64 -kernel $OUT/nomos.elf -m 128M -no-reboot \
        -debugcon stdio -serial file:/dev/stderr $QEMU_HW \
        -cpu Skylake-Server -display none
elif [ "$1" = "kvm" ]; then
    qemu-system-x86_64 -hda $OUT/nomos.img -m 128M -no-reboot \
        -debugcon stdio -serial file:/dev/stderr $QEMU_HW \
        -enable-kvm -cpu host -display none
else
    # default: MBR boot, KVM if available, GUI window
    KVM=""
    [ -w /dev/kvm ] && KVM="-enable-kvm -cpu host"
    qemu-system-x86_64 -hda $OUT/nomos.img -m 128M -no-reboot \
        -serial stdio -debugcon file:/dev/stderr $QEMU_HW \
        ${KVM:-"-cpu Skylake-Server"} -vga std
fi
